# Teacher LLM: dùng OpenAI chính thức để sinh gold labels.
# Chỉ điền OPENAI_API_KEY và TEACHER_LLM_MODEL.
# TEACHER_LLM_BASE_URL để trống khi dùng OpenAI API chính thức.
OPENAI_API_KEY=
TEACHER_LLM_MODEL=
TEACHER_LLM_BASE_URL=

# Student LLM: model 8B self-host của bạn.
STUDENT_LLM_BASE_URL=https://lumentary-model.gaussora.com/v1
STUDENT_LLM_API_KEY=
STUDENT_LLM_MODEL=qwen/qwen3-8b

# Embedding model: endpoint self-host dùng để tạo vector embedding.
EMBEDDING_BASE_URL=https://lumentary-model.gaussora.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# Không cần điền nếu đã dùng các biến ở trên.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
TEACHER_LLM_API_KEY=
STUDENT_LLM_ENDPOINT=

# Optional database
POSTGRES_DSN=
