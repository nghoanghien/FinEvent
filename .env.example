# Copy this file to .env and fill only real secrets in .env.
# Never commit .env.

# PostgreSQL/pgvector runtime from docker-compose.yml.
POSTGRES_DB=finevent
POSTGRES_USER=finevent
POSTGRES_PASSWORD=password
POSTGRES_PORT=55433
POSTGRES_DSN=postgresql+psycopg://finevent:password@localhost:55433/finevent

# Teacher LLM: official OpenAI API through LangChain.
# Leave TEACHER_LLM_BASE_URL empty for the official OpenAI API.
TEACHER_LLM_PROVIDER=langchain_openai
OPENAI_API_KEY=
TEACHER_LLM_MODEL=gpt-4o-mini
TEACHER_LLM_BASE_URL=

# Student LLM: self-host OpenAI-compatible API.
# direct_http is used because the current self-host endpoint works over direct HTTP
# while LangChain/OpenAI SDK may receive HTTP 403 from that endpoint.
STUDENT_LLM_PROVIDER=direct_http
STUDENT_LLM_BASE_URL=https://lumentary-model.gaussora.com/v1
STUDENT_LLM_API_KEY=
STUDENT_LLM_MODEL=qwen/qwen3-8b
STUDENT_LLM_DISABLE_THINKING=true
STUDENT_LLM_MAX_TOKENS=1536

# Embedding model: self-host OpenAI-compatible embeddings API.
EMBEDDING_PROVIDER=direct_http
EMBEDDING_BASE_URL=https://lumentary-model.gaussora.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=1024

# Legacy/optional aliases. Keep empty unless needed.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
TEACHER_LLM_API_KEY=
STUDENT_LLM_ENDPOINT=
