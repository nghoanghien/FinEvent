{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finevent.local/schema/event_schema_v1.json",
  "title": "FinEvent Vietnamese Corporate Event Label",
  "type": "object",
  "required": [
    "article_id",
    "document_label",
    "label_reason",
    "events",
    "warnings",
    "model_info"
  ],
  "additionalProperties": false,
  "properties": {
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "document_label": {
      "type": "string",
      "enum": [
        "HAS_EVENT",
        "NO_EVENT",
        "UNCERTAIN"
      ]
    },
    "label_reason": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_info": {
      "type": "object",
      "required": [
        "model_name",
        "prompt_version",
        "run_id"
      ],
      "additionalProperties": true,
      "properties": {
        "model_name": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": [
        "event_id",
        "ticker",
        "company_name",
        "event_type",
        "event_subtype",
        "event_summary",
        "event_reason",
        "event_arguments",
        "impact_sentiment",
        "evidence_span",
        "source_url",
        "published_at",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "company_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_type": {
          "type": "string",
          "enum": [
            "MA",
            "CONTRACT",
            "CAPITAL",
            "LEADERSHIP",
            "EXPANSION",
            "LEGAL_RISK",
            "PARTNERSHIP",
            "LICENSE_APPROVAL",
            "BUSINESS_RESULT",
            "ASSET_TRANSACTION",
            "DEBT_CREDIT",
            "DIVIDEND_SHAREHOLDER",
            "PRODUCT_SERVICE",
            "MARKET_LISTING",
            "ESG_OPERATIONAL_RISK",
            "OTHER"
          ]
        },
        "event_subtype": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_summary": {
          "type": "string",
          "minLength": 1
        },
        "event_reason": {
          "type": "string",
          "minLength": 1
        },
        "event_arguments": {
          "type": "object"
        },
        "impact_sentiment": {
          "type": "string",
          "enum": [
            "POSITIVE",
            "NEGATIVE",
            "NEUTRAL",
            "MIXED"
          ]
        },
        "evidence_span": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string"
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
